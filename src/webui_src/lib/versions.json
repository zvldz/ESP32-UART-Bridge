{
  "description": "Alpine.js libraries for ESP32 UART Bridge Web UI",
  "updated": "2026-02-15",
  "libraries": {
    "alpine": {
      "version": "3.15.8",
      "file": "alpine.min.js",
      "url": "https://cdn.jsdelivr.net/npm/alpinejs@3.15.8/dist/cdn.min.js",
      "docs": "https://alpinejs.dev/start-here"
    },
    "alpine-persist": {
      "version": "3.15.8",
      "file": "alpine-persist.min.js",
      "url": "https://cdn.jsdelivr.net/npm/@alpinejs/persist@3.15.8/dist/cdn.min.js",
      "docs": "https://alpinejs.dev/plugins/persist"
    },
    "alpine-collapse": {
      "version": "3.15.8",
      "file": "alpine-collapse.min.js",
      "url": "https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.15.8/dist/cdn.min.js",
      "docs": "https://alpinejs.dev/plugins/collapse"
    },
    "xterm": {
      "version": "5.5.0",
      "files": ["xterm.js", "xterm.css"],
      "url_js": "https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/lib/xterm.js",
      "url_css": "https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/css/xterm.css",
      "docs": "https://xtermjs.org/",
      "notes": "Loaded dynamically when ANSI mode enabled, not included in initial page load"
    },
    "xterm-addon-fit": {
      "version": "0.10.0",
      "files": ["xterm-addon-fit.js"],
      "url_js": "https://cdn.jsdelivr.net/npm/@xterm/addon-fit@0.10.0/lib/addon-fit.js",
      "notes": "Auto-resize xterm to container dimensions"
    }
  },
  "loadOrder": [
    "alpine-persist.min.js",
    "alpine-collapse.min.js",
    "alpine.min.js"
  ],
  "notes": "Plugins must be loaded BEFORE alpine.min.js. xterm.js loaded on demand."
}
